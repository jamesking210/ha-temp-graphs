# Home Assistant URL
HA_URL=http://192.168.1.3:8123

# Create this in Home Assistant under your user profile > Long-Lived Access Tokens
HA_TOKEN=changeme

# App settings
PORT=8090
POLL_SECONDS=300
DB_PATH=/app/data/temps.sqlite3

# Sensors/entities to track
OUTSIDE_ENTITY_ID=weather.home
OUTSIDE_VALUE_SOURCE=attributes.temperature
OUTSIDE_LABEL=Outside Temp

HALLWAY_ENTITY_ID=sensor.public_hallway_temp_sensor_temperature
HALLWAY_VALUE_SOURCE=state
HALLWAY_LABEL=Public Hallway Temp
